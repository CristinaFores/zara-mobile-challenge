{
  "name": "zara-mobile-catalog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "lint:styles": "stylelint \"src/**/*.scss\" --allow-empty-input",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "env -u PLAYWRIGHT_BROWSERS_PATH playwright test",
    "test:e2e:headed": "env -u PLAYWRIGHT_BROWSERS_PATH playwright test --headed --workers=1 --project=chromium",
    "test:e2e:debug": "env -u PLAYWRIGHT_BROWSERS_PATH playwright test --debug --workers=1 --project=chromium",
    "test:e2e:ui": "rm -rf test-results playwright-report && env -u PLAYWRIGHT_BROWSERS_PATH E2E_UI=1 PLAYWRIGHT_TRACING_NO_WEBSOCKET_FRAMES=1 playwright test --ui --project=chromium",
    "playwright:install": "env -u PLAYWRIGHT_BROWSERS_PATH playwright install chromium",
    "prepare": "husky"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "embla-carousel-react": "^8.6.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@eslint/js": "^9.39.0",
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^17.0.7",
    "msw": "^2.14.6",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.4",
    "sass": "^1.101.0",
    "stylelint": "^17.13.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.46.0",
    "undici": "^6.27.0"
  },
  "lint-staged": {
    "{src,e2e}/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "src/**/*.scss": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
