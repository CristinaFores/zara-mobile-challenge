# External API (challenge documentation)
# Server-side only — never expose these to the browser (do not prefix with NEXT_PUBLIC_).
API_BASE_URL=
API_KEY=

# Own host — used by the service layer to call our Next.js API routes.
# Set to your deployment URL in production (e.g. https://your-app.vercel.app).
APP_URL=http://localhost:3000
